{
  "name": "fabora",
  "type": "module",
  "packageManager": "yarn@4.13.0",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/node": "^25.5.0",
    "conventional-changelog-atom": "^5.1.0",
    "lefthook": "^2.1.4",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript": "^6.0.2"
  },
  "scripts": {
    "dev": "yarn workspaces foreach -A -p -i -t run dev",
    "lint": "yarn workspaces foreach -A -p -i -t run lint",
    "lint:fix": "yarn workspaces foreach -A -p -i -t run lint:fix",
    "build": "yarn workspaces foreach -A -p -i -t run build",
    "format:fix": "prettier --write ."
  }
}
